{
  "name": "neo10-webtool",
  "private": true,
  "version": "0.1.0",
  "homepage": "https://T-Anh17.github.io/esp32_sim_neo10/",
  "scripts": {
    "dev": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "predeploy": "npm run build && (if exist dist_gh rmdir /s /q dist_gh) && mkdir dist_gh && xcopy /e /y dist dist_gh",
    "deploy": "cd dist_gh && git init && git add . && git commit -m \"Deploy Webtool\" && git push -f https://T-Anh17@github.com/T-Anh17/esp32_sim_neo10.git master:gh-pages"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.15",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "css-loader": "^7.1.2",
    "dotenv": "^16.4.7",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  }
}
